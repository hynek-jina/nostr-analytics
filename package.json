{
  "name": "nostr-analytics",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @nostr-analytics/dashboard dev",
    "build": "bun run --filter @nostr-analytics/dashboard build",
    "preview": "bun run --filter @nostr-analytics/dashboard preview",
    "eslint": "bun run --workspaces --if-present eslint",
    "prettier": "bun run --workspaces --if-present prettier",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "check-code": "bun run typecheck && bun run eslint && bun run prettier"
  }
}
